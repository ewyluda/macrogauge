{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "compare",
  "type": "object",
  "required": ["published_at", "months", "official_yoy_pct", "official_core_yoy_pct",
               "gauge_yoy_pct", "col_yoy_pct", "tracker_yoy_pct", "supercore_yoy_pct",
               "pce_yoy_pct", "validation"],
  "additionalProperties": false,
  "properties": {
    "published_at": {"type": "string"},
    "months": {"type": "array",
               "items": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}},
    "official_yoy_pct": {"type": "array", "items": {"type": "number"}},
    "official_core_yoy_pct": {"type": "array", "items": {"type": ["number", "null"]}},
    "gauge_yoy_pct": {"type": "array", "items": {"type": ["number", "null"]}},
    "col_yoy_pct": {"type": "array", "items": {"type": ["number", "null"]}},
    "tracker_yoy_pct": {"type": "array", "items": {"type": ["number", "null"]}},
    "supercore_yoy_pct": {"type": "array", "items": {"type": ["number", "null"]}},
    "pce_yoy_pct": {"type": "array", "items": {"type": ["number", "null"]}},
    "validation": {
      "type": "object",
      "required": ["gauge", "col", "tracker", "supercore", "pce"],
      "additionalProperties": false,
      "properties": {
        "gauge": {"$ref": "#/$defs/stats"},
        "col": {"$ref": "#/$defs/stats"},
        "tracker": {"$ref": "#/$defs/stats"},
        "supercore": {"$ref": "#/$defs/stats"},
        "pce": {"$ref": "#/$defs/stats"}
      }
    }
  },
  "$defs": {
    "stats": {
      "type": "object",
      "required": ["corr", "mean_abs_gap_pp", "window"],
      "additionalProperties": false,
      "properties": {
        "corr": {"type": ["number", "null"], "minimum": -1, "maximum": 1},
        "mean_abs_gap_pp": {"type": ["number", "null"]},
        "window": {"type": "string"},
        "lead_lag": {"oneOf": [
          {"type": "null"},
          {"type": "object",
           "required": ["best_shift_months", "corr"],
           "additionalProperties": false,
           "properties": {
             "best_shift_months": {"type": "integer", "minimum": 0, "maximum": 6},
             "corr": {"type": "number", "minimum": -1, "maximum": 1}}}]}
      }
    }
  }
}
